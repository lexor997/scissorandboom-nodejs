<%- include('partials/_head', {
  title: "Scissor Lift & Boom Lift Hire Auckland | Scissor And Boom NZ",
  description: "Scissor lift and boom lift hire in Auckland. Electric & diesel machines up to 26.6m working height. Fast delivery across Auckland, Northland & Waikato. Call 0800 250 081.",
  canonical: "/"
}) %>
<%- include('partials/_nav', { page: "home" }) %>

<!-- Hero -->
<section class="hero">
  <div class="container py-5">
    <div class="row align-items-center g-4">
      <div class="col-lg-6 py-4 text-white">
        <span class="section-label" style="color:#e6cc17;">Auckland &amp; Greater NZ</span>
        <h1>Height Access Equipment — Reliable, Safe &amp; Ready to Hire</h1>
        <p class="mt-3 mb-4">From compact electric scissor lifts to 26m diesel boom lifts, Scissor and Boom has the machine for your job. Delivered on time, every time.</p>
        <div class="d-flex flex-wrap gap-3">
          <a href="/equipment" class="btn-primary-custom">View Equipment</a>
          <a href="/pricing" class="btn-outline-white">See Pricing</a>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="inquiry-card p-4">
          <h3 class="text-uppercase text-custom fw-bold mb-1" style="font-size:1.1rem;">Get a Free Quote</h3>
          <p class="text-white mb-3" style="font-size:.9rem;">We'll call you back within the hour.</p>
          <div id="heroSuccess" class="d-none text-center py-3">
            <i class="bi bi-check-circle-fill text-custom" style="font-size:2rem;"></i>
            <p class="text-white mt-2 mb-0">Thanks! We'll call you back within the hour.</p>
          </div>
          <form id="heroForm">
            <input type="text" class="form-control mb-2" name="full_name" placeholder="Full Name" required>
            <input type="text" class="form-control mb-2" name="phone_number" placeholder="Phone Number" required>
            <input type="email" class="form-control mb-2" name="email" placeholder="Email Address">
            <textarea class="form-control mb-3" name="message" placeholder="What equipment do you need?" rows="3" style="background:rgba(255,255,255,.10);border:1px solid rgba(255,255,255,.22);color:#fff;border-radius:8px;padding:.65rem 1rem;width:100%;"></textarea>
            <button type="submit" id="heroSubmit" class="btn-primary-custom w-100">
              <span id="heroBtnText">Send Enquiry</span>
              <span id="heroSpinner" class="d-none">Sending...</span>
            </button>
          </form>
          <script>
            document.getElementById('heroForm').addEventListener('submit', async function(e) {
              e.preventDefault();
              const btn = document.getElementById('heroSubmit');
              document.getElementById('heroBtnText').classList.add('d-none');
              document.getElementById('heroSpinner').classList.remove('d-none');
              btn.disabled = true;
              try {
                const res = await fetch('/api/contact', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify(Object.fromEntries(new FormData(this)))
                });
                if (res.ok) {
                  this.classList.add('d-none');
                  document.getElementById('heroSuccess').classList.remove('d-none');
                } else { throw new Error(); }
              } catch {
                btn.disabled = false;
                document.getElementById('heroBtnText').classList.remove('d-none');
                document.getElementById('heroSpinner').classList.add('d-none');
              }
            });
          </script>
        </div>
      </div>
    </div>
  </div>
</section>

