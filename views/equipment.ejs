    <style>
      #equipFilter .nav-link { cursor:pointer; }
    </style>
    <script>
      document.getElementById('equipFilter').addEventListener('click', function(e) {
        const btn = e.target.closest('[data-filter]');
        if (!btn) return;
        // Update active button
        this.querySelectorAll('[data-filter]').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        // Show/hide cards
        const filter = btn.dataset.filter;
        document.querySelectorAll('#equipRow > [data-cat]').forEach(card => {
          card.style.display = (filter === 'all' || card.dataset.cat === filter) ? '' : 'none';
        });
      });
    </script>


